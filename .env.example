# Copy to .env and fill in.

# --- Search API (Wenyon /api/v1/search) ---------------------------------
# Where the deployed search service is reachable FROM WHERE YOU RUN THE DEMO.
# The svc-... name only resolves inside the VolcEngine cluster / dev box; from a
# laptop, use an SSH tunnel (ssh -L 8080:svc-...:8080 ...) and localhost.
SEARCH_API_BASE_URL=http://svc-6b1533bd53c9cead9d6c-svc-0613b2860e4195ef8cce:8080
SEARCH_USER_ID=user_123
# Optional business-isolation tag (sent as `scene` when set).
# SEARCH_SCENE=

# --- LLM loop (Anthropic-compatible gateway) ----------------------------
# Needed for the default planning/extraction/synthesis loop. Run with --no-llm
# (and --mock) to skip entirely and stay fully offline.
ANTHROPIC_API_KEY=sk-ant-...
# Optional: use an Anthropic-compatible gateway instead of api.anthropic.com.
# Example for GPUGeek:
#   ANTHROPIC_BASE_URL=https://api.gpugeek.com
#   MEMORY_DR_MODEL=Vendor2/Claude-4.6-opus
# ANTHROPIC_BASE_URL=
# MEMORY_DR_MODEL=claude-sonnet-4-6
